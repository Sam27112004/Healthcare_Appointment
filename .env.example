# ═══════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════
APP_NAME=Healthcare Appointment Manager
APP_ENV=development                          # development | staging | production
DEBUG=true                                   # Enable debug logging and SQL echo
API_V1_PREFIX=/api/v1

# ═══════════════════════════════════════════
# DATABASE (PostgreSQL)
# ═══════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/healthcare_db

# Connection pool settings
DB_POOL_SIZE=20                              # Base pool connections
DB_MAX_OVERFLOW=10                           # Additional connections under load
DB_POOL_TIMEOUT=30                           # Seconds to wait for connection
DB_POOL_RECYCLE=1800                         # Recycle connections every 30 min

# ═══════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════
# AUTHENTICATION (JWT)
# ═══════════════════════════════════════════
JWT_SECRET_KEY=                              # Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ═══════════════════════════════════════════
# AI / GEMINI
# ═══════════════════════════════════════════
GEMINI_API_KEY=                              # Get from https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-3.1-flash               # or gemini-3.1-flash-lite
AI_TIMEOUT_SECONDS=30                        # Timeout for AI API calls
AI_MAX_RETRIES=3                             # Max retry attempts for AI tasks

# ═══════════════════════════════════════════
# EMAIL (SMTP)
# ═══════════════════════════════════════════
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=                               # Gmail App Password (not regular password)
MAIL_FROM=noreply@healthcare-app.com
MAIL_FROM_NAME=Healthcare Appointment Manager
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ═══════════════════════════════════════════
# GOOGLE CALENDAR (OAuth 2.0)
# ═══════════════════════════════════════════
GOOGLE_CLIENT_ID=                            # From Google Cloud Console
GOOGLE_CLIENT_SECRET=                        # From Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/callback

# ═══════════════════════════════════════════
# SLOT CONFIGURATION
# ═══════════════════════════════════════════
SLOT_HOLD_TTL_SECONDS=600                    # 10 minutes hold before expiry
SLOT_GENERATION_DAYS_AHEAD=30                # Generate slots for the next N days

# ═══════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════
RATE_LIMIT_AUTH=10/minute                    # Login/register rate limit
RATE_LIMIT_HOLD=5/minute                     # Slot hold rate limit
RATE_LIMIT_GENERAL=100/minute                # General API rate limit

# ═══════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════
FRONTEND_URL=http://localhost:5173           # Allowed origin for CORS

# ═══════════════════════════════════════════
# CELERY
# ═══════════════════════════════════════════
CELERY_BROKER_URL=redis://localhost:6379/0   # Same as REDIS_URL typically
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=4                  # Number of worker processes

# ═══════════════════════════════════════════
# FRONTEND CONFIGURATION
# ═══════════════════════════════════════════
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Healthcare Appointment Manager
VITE_SLOT_HOLD_TTL=600                       # Must match backend SLOT_HOLD_TTL_SECONDS
